{
  "name": "aetherems-console",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:type-check": "run-p type-check \"build-only {@}\" --",
    "build:check": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "docker:deploy": "powershell -ExecutionPolicy Bypass -File scripts/docker-deploy.ps1",
    "docker:deploy:fresh": "powershell -ExecutionPolicy Bypass -File scripts/docker-deploy.ps1 -NoCache",
    "docker:deploy:arm64": "powershell -ExecutionPolicy Bypass -File scripts/docker-deploy.ps1 -Mode export",
    "docker:deploy:multi": "powershell -ExecutionPolicy Bypass -File scripts/docker-deploy.ps1 -Mode push -Registry",
    "quality:report": "node scripts/quality-report.mjs",
    "quality:check": "node scripts/quality-report.mjs --out reports/quality/quality-report.md",
    "type-check": "vue-tsc --build",
    "type-check:only": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "lint:check": "eslint . --max-warnings=0",
    "format": "prettier --write src/",
    "format:check": "prettier --check .",
    "audit:check": "pnpm audit --audit-level=moderate --registry=https://registry.npmjs.org"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.5",
    "@element-plus/icons-vue": "^2.3.1",
    "@types/crypto-js": "^4.2.2",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.1",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/core": "^14.0.0",
    "autofit.js": "^3.2.8",
    "axios": "^1.15.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.19",
    "echarts": "^6.0.0",
    "element-plus": "^2.14.3",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.4.1",
    "uuid": "^13.0.0",
    "v-fit-columns": "^0.2.0",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1",
    "vue-virtual-scroller": "2.0.1"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.32",
    "@types/postcss-load-config": "^3.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.23",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.5",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.4.2",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "postcss-pxtorem": "^6.1.0",
    "prettier": "3.9.5",
    "rollup-plugin-visualizer": "^6.0.3",
    "sass-embedded": "^1.89.2",
    "terser": "^5.43.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^8.1.3",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.2.10"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
